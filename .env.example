# ── Server ──────────────────────────────────────────────────────────────────
PORT=8000

# ── Autenticazione API ───────────────────────────────────────────────────────
# Chiave di lettura (header X-API-Key) — accesso a /analyze, /frame, GET su cataloghi
API_PASSWORD=

# Chiave amministratore (header X-Admin-Key) — CRUD su /cameras, /actions, /sequences
API_ADMIN_PASSWORD=

# ── LLM ─────────────────────────────────────────────────────────────────────
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o
LLM_REASONING=false        # true = abilita extra_body.enable_thinking (Step 2)
LLM_TIMEOUT=60
LLM_CONTEXT_WINDOW=64000

# ── Telecamere Axis ──────────────────────────────────────────────────────────
# Credenziali default usate per tutte le telecamere (DigestAuth VAPIX)
# NON inserire credenziali in cameras.yaml — usare solo queste variabili
AXIS_DEFAULT_USER=root
AXIS_DEFAULT_PASS=

# ── Arize Phoenix (observability LLM) ────────────────────────────────────────
# Lasciare PHOENIX_URL vuoto per disabilitare il tracing (tutto continua a funzionare)
PHOENIX_URL=http://localhost:6006
PHOENIX_API_KEY=
